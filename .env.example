# Copy to .env and fill in. Only ANTHROPIC_API_KEY is strictly required to
# generate answers; everything else has sensible defaults.

# LLM (required for /query)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-8
# Token-frugal defaults. Raise LLM_EFFORT to high and LLM_THINKING to adaptive
# for harder corpora (better answers, more tokens).
LLM_EFFORT=low
LLM_THINKING=disabled
LLM_MAX_TOKENS=1024

# Token optimisation
# Cap on retrieved context sent to Claude (estimated tokens). Lower = cheaper.
MAX_CONTEXT_TOKENS=1200
# In-memory answer cache size; identical repeated queries then cost 0 tokens.
ANSWER_CACHE_SIZE=256

# Database
# Matches the bundled docker-compose 'db' service.
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# Embeddings
# fastembed (local, default) or voyage (hosted).
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# For Voyage AI instead (voyage-3 needs EMBEDDING_DIM=1024):
# EMBEDDING_PROVIDER=voyage
# EMBEDDING_MODEL=voyage-3
# EMBEDDING_DIM=1024
# VOYAGE_API_KEY=

# Chunking / retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.2

ENVIRONMENT=dev
LOG_LEVEL=INFO
